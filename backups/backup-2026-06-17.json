    "FAQ": [
      {
        "_id": "6a2cecc0f3710656686c7af1",
        "question": "What is the typical timeline for an interior design project?",
        "answer": "The timeline varies based on scope. A single room takes 4-6 weeks, while a full home or office project can take 2-4 months. We provide a detailed timeline during consultation.",
        "order": 1,
        "isActive": true,
        "createdAt": "2026-06-13T05:38:08.855Z",
        "updatedAt": "2026-06-13T05:38:08.855Z"
      },
      {
        "_id": "6a2cecc0f3710656686c7af2",
        "question": "How much do interior design services cost?",
        "answer": "Our pricing is transparent and customized to your needs. We offer different packages from basic consultation to full turnkey solutions. Contact us for a detailed quote.",
        "order": 2,
        "isActive": true,
        "createdAt": "2026-06-13T05:38:08.857Z",
        "updatedAt": "2026-06-13T05:38:08.857Z"
      },
      {
        "_id": "6a2cecc0f3710656686c7af3",
        "question": "Do you offer 3D visualization before starting the project?",
        "answer": "Yes! We provide photorealistic 3D renders of your space before any work begins. This allows you to see and approve the design before execution.",
        "order": 3,
        "isActive": true,
        "createdAt": "2026-06-13T05:38:08.857Z",
        "updatedAt": "2026-06-13T05:38:08.857Z"
      },
      {
        "_id": "6a2cecc0f3710656686c7af4",
        "question": "What areas do you serve?",
        "answer": "We are based in Bangalore and serve major cities across India including Mumbai, Delhi, Pune, Hyderabad, and Chennai. For premium projects, we offer pan-India services.",
        "order": 4,
        "isActive": true,
        "createdAt": "2026-06-13T05:38:08.858Z",
        "updatedAt": "2026-06-13T05:38:08.858Z"
      },
      {
        "_id": "6a2cecc0f3710656686c7af5",
        "question": "Do you handle both residential and commercial projects?",
        "answer": "Absolutely. We specialize in both residential interiors (homes, villas, apartments) and commercial spaces (offices, retail, restaurants, hotels).",
        "order": 5,
        "isActive": true,
        "createdAt": "2026-06-13T05:38:08.858Z",
        "updatedAt": "2026-06-13T05:38:08.858Z"
      },
      {
        "_id": "6a2cecc0f3710656686c7af6",
        "question": "What is your design process?",
        "answer": "Our process includes 5 steps: Consultation, Planning, Design, Execution, and Handover. We involve you at every stage to ensure the final result matches your vision.",
        "order": 6,
        "isActive": true,
        "createdAt": "2026-06-13T05:38:08.858Z",
        "updatedAt": "2026-06-13T05:38:08.858Z"
      }
