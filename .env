# Hostinger Image Upload
# PHP handler deployed to: public_html/akinterious/upload.php
# Subdomain uploads.akinteriors.design points to public_html/akinterious/ on Hostinger
# Images stored at: public_html/akinterious/uploads/
# Public URL: http://uploads.akinteriors.design/uploads/{filename}
# NOTE: subdomain has no SSL — images proxied through Next.js Image Optimization (/api/image) avoid mixed content
#       Recommended: enable SSL in Hostinger cPanel for uploads.akinteriors.design
