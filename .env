HOSTINGER_UPLOAD_API_KEY=akinteriors-upload-key-2024
# Must match env(UPLOAD_API_KEY) in upload.php or fallback default
NEXT_PUBLIC_HOSTINGER_URL=http://uploads.akinteriors.design
